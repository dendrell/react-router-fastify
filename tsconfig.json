{
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules", "demo"],
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@types/node"],
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "declaration": true,
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true
  }
}
