{
  "name": "demo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "prestart": "pnpm build",
    "start": "NODE_ENV=production NODE_OPTIONS='--enable-source-maps --trace-uncaught' node-cluster-serve server.ts --port 3102 --host 0.0.0.0",
    "start:cluster": "WEB_CONCURRENCY=2 pnpm start",
    "typecheck": "pnpm typegen && tsc",
    "typegen": "react-router typegen"
  },
  "dependencies": {
    "@react-router/node": "^7.14.0",
    "isbot": "^5.1.37",
    "node-cluster-serve": "^0.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0",
    "react-router-fastify": "workspace:*"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
